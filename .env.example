APP_NAME="Otorite Yayin"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=odogan_cms
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

CACHE_DRIVER=file
CACHE_PATH=storage/cache

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=odogan:

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Otorite Yayin"

LOG_CHANNEL=daily
LOG_LEVEL=debug

# Sentry error tracking (boş bırakırsanız devre dışı kalır)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Brevo (Sendinblue) newsletter — API key https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_LIST_ID=
