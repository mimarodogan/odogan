# Otorite Yayin — production .env template
# Copy to .env on the production host and fill in real values.
# NEVER commit a populated .env to git.

# ────────────────────────────  APP  ────────────────────────────
APP_NAME="Otorite Yayin"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
# APP_KEY: 32-byte base64 — required for Crypto::encrypt (SMTP password,
# 2FA recovery codes, future at-rest secrets). DO NOT rotate without a
# migration; old ciphertexts become unreadable.
# Generate with: openssl rand -base64 32
APP_KEY=
APP_LOCALE=tr
APP_TIMEZONE=Europe/Istanbul

# ────────────────────────────  DB  ─────────────────────────────
# Use a dedicated DB user with the LEAST privileges needed
# (SELECT, INSERT, UPDATE, DELETE — NO DROP/ALTER/GRANT in production).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=odogan_prod
DB_USERNAME=odogan_app                     # NOT root
DB_PASSWORD=                               # strong, random — 24+ chars
DB_CHARSET=utf8mb4

# ────────────────────────────  CACHE  ──────────────────────────
CACHE_DRIVER=file
CACHE_PATH=storage/cache

# ────────────────────────────  REDIS (optional)  ───────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PREFIX=odogan:

# ────────────────────────────  MAIL  ───────────────────────────
# Use a verified sender domain with SPF + DKIM records published.
# (docs/DNS_SETUP.md → SPF, DKIM, DMARC adımları)
# Production'da SMTP parolası Settings → Mail panelinden girilince
# DB'ye Crypto::encrypt() ile şifrelenerek kaydedilir. MAIL_PASSWORD
# yalnızca DB'de mail.password ayarı boşsa fallback olarak kullanılır.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Otorite Yayin"

# ────────────────────────────  LOGGING  ────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=warning                          # production: warning or error

# ────────────────────────────  SENTRY (error tracking)  ────────
# Boş bırakırsanız bootstrap.php Sentry'yi devre dışı tutar.
# DSN format: https://<key>@<org>.ingest.sentry.io/<project>
# TRACES_SAMPLE_RATE: 0.0–1.0 arası, trafiğin yüzdesi (0.1 = %10).
# Yüksek tutmayın — kota & gürültü.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ────────────────────────────  BREVO (newsletter)  ─────────────
# Brevo (eski Sendinblue) API key — abonelik formu + bülten gönderimi.
# Panel: https://app.brevo.com/settings/keys/api
# BREVO_LIST_ID: hedef abone listesinin numerik ID'si.
BREVO_API_KEY=
BREVO_LIST_ID=
