# ====================================================
# OTORITE YAYIN - Hosting (cPanel/Plesk) icin .env
# Bu dosyayi .env olarak kopyalayip degerleri doldurun
# Yorum satiri sadece # ile baslar (; calismaz!)
# ====================================================

APP_NAME="Otorite Yayin"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://senindomainin.com
APP_LOCALE=tr
APP_TIMEZONE=Europe/Istanbul

# ----- Veritabani (cPanel > MySQL Veritabanlari'ndan olusturup buraya yazin)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=kullanici_odogan_cms
DB_USERNAME=kullanici_dbuser
DB_PASSWORD=cok-guclu-bir-parola
DB_CHARSET=utf8mb4

# ----- Cache (Redis yoksa file kullanin)
CACHE_DRIVER=file
CACHE_PATH=storage/cache

# Redis kurulu hosting'lerde asagidakileri acin (basindaki # silin):
#CACHE_DRIVER=redis
#REDIS_HOST=127.0.0.1
#REDIS_PORT=6379
#REDIS_PREFIX=odogan:

# ----- Mail (cPanel > E-posta Hesaplari'ndan olusturun)
MAIL_HOST=mail.senindomainin.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@senindomainin.com
MAIL_PASSWORD=mail-parolasi
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@senindomainin.com
MAIL_FROM_NAME="Otorite Yayin"
